# Copy to .env and adjust values:
#   cp .env.example .env

# =============================================================================
# Local development
#   docker compose up -d          → DB + Adminer
#   ./gradlew bootRun             → backend
#   cd ../email-delivery-ui && npm run dev → frontend on :8082
# =============================================================================

# --- Docker Compose (local) ---
DB_ROOT_PASSWORD=password
DB_NAME=email_delivery
DB_HOST_PORT=3319
ADMINER_HOST_PORT=8589

# --- Database (backend on host → docker DB) ---
DB_CONNECTION_IP=localhost
DB_CONNECTION_PORT=3319
DB_USERNAME=root

# --- Backend (local) ---
PORT=8090
APP_SECRET_KEY=local-dev-secret-key-change-in-production

# --- Admin bootstrap ---
ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-me
ADMIN_BOOTSTRAP_FIRST_NAME=Admin
ADMIN_BOOTSTRAP_LAST_NAME=User

# --- CORS & public URL (local) ---
ADMIN_PUBLIC_BASE_URL=http://localhost:8090
ADMIN_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*

# --- Mail (SMTP) ---
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
ADMIN_MAIL_FROM=noreply@example.com

# --- Swagger (local) ---
SPRINGDOC_API_DOCS_ENABLED=true
SPRINGDOC_SWAGGER_UI_ENABLED=true

# --- Frontend (email-delivery-ui .env — local) ---
VITE_ADMIN_API_URL=http://localhost:8090/admin/v1

# =============================================================================
# Prod deploy (server: docker compose -f docker-compose.prod.yml --env-file .env)
#   Tam nümunə: cp .env.prod.example .env
# =============================================================================

# BACKEND_HOST_PORT=8092
# FRONTEND_HOST_PORT=8093
# ADMIN_PUBLIC_BASE_URL=http://your-server:8092
# ADMIN_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,http://your-server:8093
# VITE_ADMIN_API_URL=http://your-server:8092/admin/v1
BACKEND_IMAGE=ingressgroup/email-delivery-backend:v1.0.0.0
FRONTEND_IMAGE=ingressgroup/email-delivery-frontend:v1.0.0.0
