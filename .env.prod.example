# Prod server .env — copy to server:
#   cp .env.prod.example .env

# --- Host ports ---
BACKEND_HOST_PORT=8091
FRONTEND_HOST_PORT=8093

# --- Database ---
DB_ROOT_PASSWORD=change-this-root-password
DB_NAME=email_delivery
DB_USERNAME=root

# --- Backend ---
APP_SECRET_KEY=change-this-jwt-secret
ADMIN_BOOTSTRAP_ENABLED=true
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=change-this-admin-password
ADMIN_PUBLIC_BASE_URL=http://your-server:8091
ADMIN_CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*,http://your-server:8093

# --- Mail (SMTP) ---
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
ADMIN_MAIL_FROM=noreply@example.com

# --- Frontend build-time API URL (backend public URL) ---
VITE_ADMIN_API_URL=http://your-server:8091/admin/v1

# --- Docker images (GitHub Actions hər deploy-da tag yeniləyir) ---
BACKEND_IMAGE=ingressgroup/email-delivery-backend:v1.0.0.0
FRONTEND_IMAGE=ingressgroup/email-delivery-frontend:v1.0.0.0

# --- Deploy path (GitHub Actions DEPLOY_PATH secret) ---
# DEPLOY_PATH=/root/email-delivery
